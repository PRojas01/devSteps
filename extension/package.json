{
  "name": "sp-devsteps-editor",
  "displayName": "SP-devSteps",
  "description": "Panel de control de devSteps para VS Code, Cursor y Windsurf.",
  "version": "1.0.0",
  "publisher": "solucionespro",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onView:devsteps.controlPanel",
    "onCommand:devsteps.status",
    "onCommand:devsteps.validate",
    "onCommand:devsteps.run",
    "onCommand:devsteps.inject",
    "onCommand:devsteps.registerMcp",
    "onCommand:devsteps.openTerminal"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devsteps",
          "title": "devSteps",
          "icon": "media/devsteps.svg"
        }
      ]
    },
    "views": {
      "devsteps": [
        {
          "id": "devsteps.controlPanel",
          "name": "Panel"
        }
      ]
    },
    "commands": [
      {
        "command": "devsteps.status",
        "title": "devSteps: Estado",
        "category": "devSteps"
      },
      {
        "command": "devsteps.validate",
        "title": "devSteps: Validar",
        "category": "devSteps"
      },
      {
        "command": "devsteps.run",
        "title": "devSteps: Ejecutar Pipeline",
        "category": "devSteps"
      },
      {
        "command": "devsteps.inject",
        "title": "devSteps: Inyectar Agentes",
        "category": "devSteps"
      },
      {
        "command": "devsteps.registerMcp",
        "title": "devSteps: Registrar MCP",
        "category": "devSteps"
      },
      {
        "command": "devsteps.openTerminal",
        "title": "devSteps: Abrir Terminal",
        "category": "devSteps"
      }
    ]
  },
  "scripts": {
    "package": "vsce package",
    "validate": "node -e \"JSON.parse(require('fs').readFileSync('package.json','utf8')); console.log('extension package.json ok')\""
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.0"
  }
}

